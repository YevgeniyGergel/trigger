# Timezone: all working-hours/blocked-range/calendar arithmetic uses Node's
# server-local Date methods, so TZ must be pinned to Europe/Kyiv — otherwise
# a UTC-default host (e.g. Vercel) would shift every schedule by 2-3 hours.
# Already set via `cross-env` in package.json scripts for dev/build/test;
# for production also set TZ=Europe/Kyiv directly in Vercel's env vars.
TZ="Europe/Kyiv"

# Database (EU region — Neon/Railway Frankfurt)
DATABASE_URL="postgresql://user:password@host:5432/trigger?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 (S3-compatible object storage, EU data residency)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="trigger-session-audio"

# Note encryption (application-level, KMS-backed key — see design.md)
# MVP placeholder: 32-byte base64 key used directly. Replace with real KMS-issued key before production.
NOTE_ENCRYPTION_KEY=""

# Transcription (Whisper API)
OPENAI_API_KEY=""

# SOAP structuring (Claude API)
ANTHROPIC_API_KEY=""

# Email notifications (transactional provider)
RESEND_API_KEY=""
EMAIL_FROM="Trigger <notifications@trigger.example>"

# Telegram bot (outbound notifications only)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""

# Public base URL, used for deep-links (Telegram linking, booking confirmation emails)
APP_BASE_URL="http://localhost:3000"
