# Timezone: dev/build/test scripts pin TZ=Europe/Kyiv via `cross-env` in
# package.json for convenience, but nothing in the app actually depends on
# process.env.TZ — all working-hours/slot/calendar/display logic converts
# explicitly via lib/timezone.ts, since Vercel reserves TZ and won't let it
# be set from the dashboard.
TZ="Europe/Kyiv"

# Database (EU region — Neon/Railway Frankfurt)
DATABASE_URL="postgresql://user:password@host:5432/trigger?schema=public"
# Direct (non-pooled) connection, required for `prisma migrate deploy` — a
# pooled/PgBouncer endpoint (e.g. Neon's "-pooler" host) doesn't support the
# session-level advisory lock migrations take, and deploy will time out with
# error P1002 trying to acquire it.
DIRECT_URL="postgresql://user:password@host:5432/trigger?schema=public"

# NextAuth (Auth.js v5)
AUTH_SECRET="generate-with: npx auth secret"
NEXTAUTH_URL="http://localhost:3000"

# Cloudflare R2 (S3-compatible object storage, EU data residency)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="trigger-session-audio"

# Note encryption (application-level, KMS-backed key — see design.md)
# MVP placeholder: 32-byte base64 key used directly. Replace with real KMS-issued key before production.
NOTE_ENCRYPTION_KEY=""

# Application-level encryption for stored secrets (currently: LiqPay private
# keys). MVP placeholder: 32-byte base64 key used directly — generate with
# `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`.
# Replace with a real KMS-issued key before production (see design.md).
CREDENTIALS_ENCRYPTION_KEY=""

# Transcription (Whisper API)
OPENAI_API_KEY=""

# SOAP structuring (Claude API)
ANTHROPIC_API_KEY=""

# Email notifications (transactional provider)
RESEND_API_KEY=""
EMAIL_FROM="Trigger <notifications@trigger.example>"

# Telegram bot (outbound notifications only)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_BOT_USERNAME=""
# Set the same value when registering the webhook (setWebhook secret_token) —
# Telegram echoes it back on every request so /api/telegram/webhook can
# reject requests that didn't actually come from Telegram.
TELEGRAM_WEBHOOK_SECRET=""

# Public base URL, used for deep-links (Telegram linking, booking confirmation emails)
APP_BASE_URL="http://localhost:3000"

# Secret shared with Vercel Cron to authenticate calls to /api/cron/reminders
CRON_SECRET=""
